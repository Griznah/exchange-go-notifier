# exchange-go-notifier environment file.
# Copy to .env and fill in your keys:   cp .env.example .env
# Then run:
#   podman run --userns=keep-id --env-file .env -p 8080:8080 \
#     -v ./data:/data localhost/exchange-go-notifier:dev

# ExchangeRate-API (er-a) - get a key from https://www.exchangerate-api.com/
EXCHANGERATE_API_KEY=your_api_key_here

# Open Exchange Rates (oer) - get an app id from https://openexchangerates.org/
OPENEXCHANGERATES_APP_ID=your_app_id_here

# Where the app persists request counters. With the -v ./data:/data mount this is
# /data/api_state.json inside the container (./data/api_state.json on the host).
# Optional for local `go run .`; defaults to api_state.json in the working dir.
API_STATE_FILE=/data/api_state.json
